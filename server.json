{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.GeiserX/genieacs-mcp",
  "description": "MCP server bridging GenieACS TR-069 ACS instances to LLMs for CPE device management",
  "repository": {
    "url": "https://github.com/GeiserX/genieacs-mcp",
    "source": "github"
  },
  "version": "0.0.11",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "genieacs-mcp",
      "version": "0.0.11",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "ACS_URL",
          "description": "GenieACS NBI API URL (e.g. http://genieacs:7557)",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "ACS_USER",
          "description": "GenieACS NBI basic-auth username",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "ACS_PASS",
          "description": "GenieACS NBI basic-auth password",
          "isRequired": false,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ]
}
